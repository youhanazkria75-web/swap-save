# Runtime
# Production must set NODE_ENV=production so startup safety checks and Express hardening use production mode.
NODE_ENV=development
PORT=5000

# Core backend configuration required in production
MONGO_URI=your_mongodb_connection_string
JWT_SECRET=your_super_secret_key

# Frontend origin used by CORS and email/password reset links.
# Production must set at least FRONTEND_URL or CLIENT_URL to the deployed frontend origin.
CLIENT_URL=http://localhost:5500
FRONTEND_URL=http://localhost:3000

# Keep false in production unless API docs are intentionally exposed and restricted.
ENABLE_API_DOCS=false

# Local uploads are stored under back-end/uploads and served from /uploads.
# In production, keep this false until a persistent disk/volume is attached.
# Ephemeral hosting will lose uploaded product images and avatars on restart/redeploy.
LOCAL_UPLOADS_PERSISTENCE_ACK=false

# Optional Google OAuth. If one Google value is set in production, set all three.
GOOGLE_CLIENT_ID=your_google_oauth_client_id
GOOGLE_CLIENT_SECRET=your_google_oauth_client_secret
GOOGLE_CALLBACK_URL=http://localhost:5000/auth/google/callback

# SMTP is required in production for email verification and password reset flows.
SMTP_HOST=smtp.your-email-provider.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your_real_smtp_username
SMTP_PASS=your_real_smtp_password_or_app_password
SMTP_FROM="Swap & Save <no-reply@your-domain.com>"
SMTP_REPLY_TO="Swap & Save Support <support@your-domain.com>"

# Optional Twilio Verify. If one Twilio value is set in production, set all three.
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_VERIFY_SERVICE_SID=your_twilio_verify_service_sid

# Paymob is required in production for coin checkout and swap service-fee checkout.
PAYMOB_API_KEY=your_paymob_api_key
PAYMOB_INTEGRATION_ID=your_paymob_card_integration_id
PAYMOB_IFRAME_ID=your_paymob_iframe_id
PAYMOB_HMAC_SECRET=your_paymob_hmac_secret
PAYMOB_CURRENCY=EGP
PAYMOB_WEBHOOK_URL=https://your-api-domain.com/payments/paymob/webhook
PAYMOB_SUCCESS_URL=https://your-frontend-domain.com/user/coins/payment/success
PAYMOB_FAILURE_URL=https://your-frontend-domain.com/user/coins/payment/failure

# Production bootstrap admin:
# Set a real admin email and a strong unique password before deploying.
ADMIN_EMAIL=your_admin_email@example.com
ADMIN_PASSWORD=change_me_to_a_strong_unique_password
ADMIN_FIRST_NAME=System
ADMIN_LAST_NAME=Admin
